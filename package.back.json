{
  "name": "ddrs",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev:client": "cd src/client && ng serve",
    "dev:server:old": "cd src/server && nodemon app.ts",
    "dev:server:esm": "cd src/server && nodemon --exec node --loader ts-node/esm src/server/app.ts",
    "dev:server": "nodemon --watch src --ext ts --exec node --loader ts-node/esm src/server/app.ts",
    "dev": "concurrently 'npm run dev:client' 'npm run dev:server'",
    "build:client": "cd client && ng build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
